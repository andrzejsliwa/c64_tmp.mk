        jmp normal_error
; was: check_zp_optimize
chk_zp_optimize
        lda expr_result+1
        bne build_out_bytes
        lda instr_opcode
        and #%00000100
        beq build_out_bytes
        lda instr_opcode
        cmp #$4c ;jmp
        beq build_out_bytes
        cmp #$6c ;jmp ()
        beq build_out_bytes
        bit force_word_flag
        bmi build_out_bytes
        and #%11110111
        sta instr_opcode
        dec instr_length
; was: build_output_bytes
build_out_bytes
        ldx instr_length
        stx output_length
        bit pass
        bmi comp_upd_label
        lda instr_opcode
        sta opcode_buf
        dex
        beq comp_upd_label
        lda expr_result
        sta opcode_buf+1
        dex
        beq comp_upd_label
        lda expr_result+1
        sta opcode_buf+2
        jmp comp_line_done

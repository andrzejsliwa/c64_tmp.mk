        cmp #8
        bcc default_drive_8
        cmp #30
        bcc store_drive_num
default_drive_8
        lda #8
store_drive_num
        sta drive_num_ref+1
        ldx #29
save_nmi_vecs
        lda $316,x
        sta oldvectors,x
        dex
        ; end save_nmi_vecs
        bpl save_nmi_vecs
        ldx #11
save_io_vecs
        lda $300,x
        sta oldvectors2,x
        dex
        ; end save_io_vecs
        bpl save_io_vecs
        ldx currect_color_s
        lda border_colors,x
        sta VIC_BORDER_COL
        lda paper_colors,x
        sta VIC_BG_COL
        lda #<clr_mem_prompt ;206
        sta gp_ptr
        lda #>clr_mem_prompt ;202
        sta gp_ptr+1
        jsr dec_line_to_scr
        ldx currect_color_s
        lda message_colors,x
        sta line_color
        ldx #$17 ;23
        jsr draw_stat_line
        lda #$14 ;20
        jsr input_raw_entry
        cmp #$59 ;"Y"
        bne clear_mem_done
        lda #$4c ;"L"
        sta clr_mem_rts_pat
        lda #8
        sta clear_mem_loop+2
        sei
        ldy #0
        tya
clear_mem_loop
        ; self-modifying code
        sta $800,y
        iny
        ; end clear_mem_loop
        bne clear_mem_loop
        inc clear_mem_loop+2
        ; end clear_mem_loop
        bpl clear_mem_loop
        cli
clear_mem_done
        lda #$2c
        sta warm_strt_entry
; was: clear_mem_rts_patch
clr_mem_rts_pat
        rts
        .word warm_do_init
; was: clear_mem_prompt
clr_mem_prompt
        .text $63,"LEAR MEMORY (Y/N)?"
        .text $a0
; ======================================
; KERNAL VECTORS / IDE64
; ======================================
; was: reset_vectors_install_334
reset_vecto_334
        ; Save interrupt state, install
        ; default KERNAL vectors at
        ; $0314+.
        ; If IDE64 hardware detected,
        ; preserve its custom vectors
        ; instead.
        php
        sei
        jsr check_ide64
        lda #<KERNAL_IRQ_ENTR
        sta $314
        lda #>KERNAL_IRQ_ENTR
        sta $315
        ldx #29
; was: install_kernal_vec
inst_kernal_vec
        lda KERNAL_VECTORS,x
        bcc store_kern_vec
        lda oldvectors,x
; was: store_kernal_vec
store_kern_vec
        sta $316,x
        dex
        ; end inst_kernal_vec
        bpl inst_kernal_vec
        lda drive_num_ref+1
        sta $ba
        plp
        rts
;---------------------------------------
; Detect IDE64 by checking timer
; register changes and
; verifying "IDE" signature at
; $DE60-$DE62.
check_ide64
        lda IDE64_TIMER
        cmp IDE64_TIMER
        bne ide64_found
        cmp #$78
        beq ide64_not_found

ide64_found
        lda IDE64_SIGNATURE
        cmp #"I"
        bne ide64_not_found
        lda IDE64_SIGNATURE+1
        cmp #"D"
        bne ide64_not_found
        lda IDE64_SIGNATURE+2
        cmp #"E"
        bne ide64_not_found
        rts
ide64_not_found
        clc
        rts
;---------------------------------------
;---------------------------------------
irq_normal
        ; Custom IRQ: silence SID,
        ; manage key repeat speed,
        ; scan keyboard. If new key
        ; detected, set SID volume
        ; for audible click feedback.
        lda #0
        sta SID_VOLUME
        ldy $28b
        cpy #3
        blt +
        dec $28b
+       lda 198
        pha
        jsr KERNAL_SCNKEY
        pla
        cmp 198
        beq irq_normal_jmp
        lda #$0f ;15
        sta SID_VOLUME
irq_normal_jmp
        jmp KERNAL_IRQ_EXIT
oldvectors .fill 30
oldvectors2 .fill 12

        ; Compile-time check: error if
        ; code overflows into $CB00
        ; variable area
        .if *>$cb00
        .error
        ; end of compile-time
        ; conditional
        .fi

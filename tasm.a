; was: display_asm_banner
disp_asm_banner
        ; Display assembler banner with
        ; version and copyright.
        ; Calculate progress bar step
        ; size from total line count.
        jsr print_immediate
        .text $8d,$93,$0e," "
        .fill 38,"*"
        .text $8d," * ",$12,$05," ",$d4
        .text "URBO-aSS"
        .text " mAC++ EXTENDED vERSION "
        .text $90,$92," *",$8d," "
        .fill 38,"*"
        .text $8d,$8d,$90
        .text "         20090614 ",$05
        .text "sOCI/","sINGULAR",$8d,$8d
        .text $90,"      cOPYRIGHT : "
        .text $05,"oMIKRON gERMANY",$90
        .text $8d,$8d,$00
        lda memory_lines
        sta expr_result
        lda memory_lines+1
        sta expr_result+1
        lda #$26 ;"&"
        sta expr_argument
        lda #0
        sta expr_argument+1
        jsr divide_16bit
        ldy expr_result
        iny

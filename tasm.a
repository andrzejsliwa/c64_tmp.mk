; ======================================
; WRITE ASSEMBLED BYTES
; ======================================
write_opcode
        ; If no bytes to output, return.
        ; In pass 2, optionally XOR
        ; encrypt bytes, then write to
        ; file or store in memory.
        ; In pass 1, just record the
        ; start address and advance PC.
        lda output_length
        beq wr_nothing_rts
        bit pass
        bmi write_firstpass
        ldx output_length

-       lda opcode_buf,x
; was: xor_encrypt_byte
xor_encrypt_byt
        eor #0
        sta opcode_buf,x
        dex
        bpl - ; end loop
        bit prt_list_enable
        bmi advance_pc
        lda compile_to_file
        beq +
        ldx #1
        jsr KERNAL_CHKOUT

        ldy #0
-       lda opcode_buf,y
        jsr KERNAL_CHROUT
        iny
        cpy output_length
        bne - ; end loop
        jsr KERNAL_CLRCHN
        jmp advance_pc
+
        ldy output_length
        dey
        clc
        lda current_address
        adc offset

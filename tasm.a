compile_opcode
        ; Read opcode byte, determine
        ; instruction length and
        ; addressing mode. Evaluate
        ; operand expression.
        ; For branches, calculate
        ; relative offset and check
        ; range.
        ; Optimize 3-byte absolute to
        ; 2-byte zero page when
        ; possible.
        jsr get_byt_frm_com
        sta instr_opcode
        jsr get_opcode_len
        sta instr_length
        cmp #1
        beq build_out_bytes
        stx instr_addr_mode
        cmp #2
        bne eval_operand
        bit pass
        bmi build_out_bytes
eval_operand
        jsr evaluate_undef
        lda instr_length
        cmp #2
        bne chk_zp_optimize
        lda instr_addr_mode
        cmp #9
        beq +
        lda expr_result+1
        beq build_out_bytes
        jmp err_illegal_qty
+
        bit pass
        bmi build_out_bytes
        lda expr_result
        sec
        sbc current_address
        pha
        lda expr_result+1
        sbc current_address+1
        tay
        clc
        pla
        adc #$7e ;126
        bcs +
        dey
+       iny
        bne branch_out_of_r
        sec
        sbc #$80 ;128
        sta expr_result
        jmp build_out_bytes

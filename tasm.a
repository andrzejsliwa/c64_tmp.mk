; Assembly error codes in their own
; namespace (accessed as ERROR.UNDEFINED
; etc.)
ERROR   .block
DOUBLE_DEFINED  = 1
UNDEFINED       = 2
TOO_LARGE       = 3
BRANCH_RANGE    = 4
BAD_LINE        = 5
NO_DEVICE       = 6
NOT_ON_INCLUDE  = 7
ILLEGAL_CODES   = 8
MACROS_FULL     = 9
ILLEGAL_PARAM   = 10
ENDM_NO_MACRO   = 11
TOO_MANY_BLOCKS = 12
BEND_NO_BLOCK   = 13
BLOCK_OPEN      = 14
NOT_ON_CALL     = 15
LABEL_TYPE      = 16
PHASE_ERROR     = 17
GOTO_FORWARD    = 18
UNSOLVED        = 19
        .bend

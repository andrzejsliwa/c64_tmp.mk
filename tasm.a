        lda current_address+1
        adc offset+1
        sta mem_write_ptr+1
-       lda opcode_buf,y
        sta (mem_write_ptr),y
        dey
        bpl - ; end loop
advance_pc
        lda current_address
        clc
        adc output_length
        sta current_address
        bcc wr_nothing_rts
        inc current_address+1
; was: write_nothing_rts
wr_nothing_rts
        rts

write_firstpass
        bit strt_addr_noted
        bmi advance_pc
        dec strt_addr_noted
        lda current_address
        sta start_address
        lda current_address+1
        sta start_address+1
        jmp advance_pc

        rts
;---------------------------------------
; was: hex_to_screencode_1
hex_to_scrcod_1
        tax
        lda tok_work_ptr
        pha
        lda tok_work_ptr+1
        pha
        lda tok_scratch
        pha
        stx tok_work_ptr
        lda #1
        sta tok_work_ptr+1
        lda #4
        sta tok_scratch
        lda #0
        sta zp_temp_lo
        lda #0
        sta zp_temp_hi
        ldy #0

        inc curs_x_position
find_next_line
        ; Fetch each source line into
        ; buffer, render it, advance to
        ; next.
        ; Repeats for all visible screen
        ; rows.
        ; Scan each line character by
        ; character looking for the
        ; search string. Advance through
        ; lines until found or end.
        jsr fetch_ln_to_buf
        jsr adv_to_nxt_line
        dec curs_x_position
find_next_col
        inc curs_x_position
        ldx curs_x_position
        cpx find_end_col
        bge find_adv_line
        ldy #0
; was: find_compare_loop
find_compare_lp

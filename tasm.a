        pla
        sta tok_scratch
        pla
        sta tok_work_ptr+1
        pla
        sta tok_work_ptr
        ldy zp_temp_lo
        lda zp_temp_hi
        rts
; was: fill_memory_prompt
fill_mem_prompt
        .text "fILL MEMORY FROM $07E8 T"
        .text "O $"
hex_char_hi_nib
        .text "7"
hex_char_lo_nib
        .text "F"
hex_char_byte_h
        .text "E"
hex_char_byte_l
        .text "A WITH $00   "

        ; Compile-time assert: tokenizer
        ; must fit before $9FE0
        .cerror *>$9fe0

; Mnemonic table placed at $A001 (gap
; from $9FE0-$A000)
*               =$a001
; ======================================
; 6502 MNEMONIC TABLE
; ======================================
mnemonics .block
        .text "BCC","BCS","BEQ","BMI"
        .text "BNE","BPL","BVC","BVS"
        .text "BRK","CLC","CLD"
        .text "CLI","CLV","DEX","DEY"
        .text "INX","INY","NOP","PHA"
        .text "PHP","PLA","PLP"
        .text "RTI","RTS","TAX","TAY"
        .text "TSX","TXA","TXS","TYA"
        .text "SEC","SED","JSR"
        .text "SEI","OAL","ANA","ANB"
        .text "XMA","AXS","LAS","ASR"
        .text "ARR","USB","TEA"
        .text "TEX","TEY","AXM","CRP"
        .text "UNP","SKB","SKW"

        .text "EOR","STA","SBC","ROL"
        .text "ORA","LSR","LDY","LDX"
        .text "LDA","CMP","ASL"
        .text "AND","ADC","JMP","STY"
        .text "STX","ROR","INC","DEC"
        .text "CPX","CPY","BIT"
        .text "AAX","DCP","INS","RLA"
        .text "LAX","SLO","RRA","SRE"
        .bend ; end of namespace block
; Tokenizer: error/status code
tok_error
        .byte $00
; Tokenizer: comment detection flags
; was: tok_comment_flags
tok_cmt_flags
        .byte $00
; Tokenizer: output write position in
; buffer
tok_output_pos
        .byte ?
; Tokenizer: input read position
tok_input_pos
        .byte $30

; Tokenizer: saved X register
tok_temp_x .byte ?
; Tokenizer: detected addressing mode
address_mode .byte ?
; Tokenizer: opcode table index
opcode_index .byte ?

; Tokenizer: operand type flags
operand_flags
        .byte $08
; Tokenizer: saved stack pointer
tok_saved_sp
        .byte $ed
; Decimal parse: accumulator temp
tok_saved_sp_1
        .byte ?
; Tokenizer: $FF = operand field present
; was: has_operand_flag
has_oprd_flag
        .byte $ff
; Tokenizer: indirect addressing
; detected
; was: tok_indirect_flag
tok_indirect_fl
        .byte $00

; Tokenizer: parenthesis nesting counter
paren_depth .byte ?

; Tokenizer: number base radix
tok_base_radix
        .byte $03
; Tokenizer: field end position
tok_field_end

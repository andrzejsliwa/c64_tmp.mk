; ======================================
; KEYBOARD DISPATCH
; ======================================
key_commands .byte $91,$11,$1d,$9d,$8d,$0d,$14,$94,$85,$88,$89,$8c,$86,$8a,$87,$8b,$13

; .rta = store address-1 (for RTS
; dispatch: push addr-1, then RTS jumps
; there)
key_tabl .rta key_up
        .rta key_down
        .rta key_right
        .rta key_left
        .rta key_shreturn
        .rta key_return
        .rta key_delete
        .rta key_insert
        .rta key_f1
        .rta key_f7
        .rta key_f2
        .rta key_f8
        .rta key_f3
        .rta key_f4
        .rta key_f5
        .rta key_f6
        .rta key_home
;---------------------------------------
key_f3
        ldx #0
        ; BIT abs - skip next 2-byte
        ; instruction (size optimization
        ; trick)
        .byte $2c
;---------------------------------------
key_f4
        ; self-modifying code
        ldx #$10 ;16
        .byte $2c ; BIT skip trick
;---------------------------------------
key_f5
        ; self-modifying code
        ldx #$20 ;" "
        .byte $2c ; BIT skip trick
;---------------------------------------
key_f6
        ; self-modifying code
        ldx #$30 ;"0"
        lda fkey_strings,x
        beq fkey_done_rts
        sta 198
        ldy #0
fkey_buf_loop
        inx
        lda fkey_strings,x
        sta 631,y
        iny
        cpy 198
        ; end fkey_buf_loop
        blt fkey_buf_loop
fkey_done_rts
        rts
fkey_skip_rts
        rts

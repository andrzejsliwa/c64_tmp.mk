        sbc #1
        sta blk_lbl_fl_ptr+1
        sbc #1
        sta blk_lvl_tbl_ptr+1
        sta initial_mem_hi
        sta memory_bottom+1
        ; Reset error counter,
        ; macro/block state, pass
        ; counter.
        ; Fill label value store
        ; ($E000-$ECFF) with $FF
        ; (undefined).
        ; Initialize block label tables
        ; and offset register.
        lda #0
        sta error_count
        sta error_count+1
        sta mac_rec_active
        sta macro_expanding
        sta macro_nesting
        sta strt_addr_noted
        lda #$ff ;255
        sta pass
        lda #<labels_low
        sta gp_ptr
        lda #>labels_low ;236

; ======================================
; TURBO ASSEMBLER MACRO++ (TASM) - IDE64
; EXTENDED VERSION
; ======================================
; Original by Omikron Germany. Extended
; by Soci/Singular (20090614).
; Annotated for readability. All
; functionality preserved.
;
; SUBSYSTEMS:
; 1. EDITOR ($8000) 2. COMMANDS ($8B00)
; 3. TOKENIZER ($A001)
; 4. ASSEMBLER ($B400) 5. EXPRESSION
; EVAL ($C200) 6. DIRECTIVES ($BFD0)
; 7. LABELS ($BD9B) 8. MACROS ($C580) 9.
; FILE I/O (various)
;
; Source stored backwards from $7FEB.
; Line index at $CC00+.
; Labels at $E000+ under ROM. Macros
; grow down from memory_bottom.
; ======================================

; Operator constants in their own
; namespace (accessed as OPER.ADD etc.)
OPER    .block
END             = %10000
MASK            = %1111
ADD:            = 0
SUB:            = 1
MUL:            = 2
DIV:            = 3
HIGH:           = 4
LOW:            = 5
LONG:           = 6
AND:            = 7
OR:             = 8
XOR:            = 9
LPARENT:        = 10
RPARENT:        = 11
        .bend ; end of namespace block

; Set assembly origin: TASM code starts
; at $8000
*               = $8000
;---------------------------------------
; All RAM (no ROM, no I/O)
BANK_ALL_RAM    = $34
; RAM + I/O (KERNAL/BASIC out)
BANK_IO_ONLY    = $35
; RAM + I/O + KERNAL (BASIC out)
BANK_NO_BASIC   = $36
; Normal: BASIC + KERNAL + I/O
BANK_ALL_ROM    = $37
;---------------------------------------
; Control register 1
VIC_CTRL1       = $D011
VIC_MEMORY_CTRL = $D018 ; Memory control
VIC_BORDER_COL  = $D020 ; Border color
; Background color
VIC_BG_COL      = $D021
;---------------------------------------
SID_BASE        = $D400 ; SID chip base
; Volume / filter mode
SID_VOLUME      = $D418
;---------------------------------------
; CIA1 Timer B high byte
CIA1_TIMER_B_HI = $DC05
;---------------------------------------
; IDE64 timer register
IDE64_TIMER     = $DF09
; IDE64 ID ("IDE")
IDE64_SIGNATURE = $DE60
;---------------------------------------
; Output character
KERNAL_CHROUT   = $FFD2
; Input character
KERNAL_CHRIN    = $FFCF
KERNAL_OPEN     = $FFC0 ; Open file
KERNAL_CLOSE    = $FFC3 ; Close file
; Set input channel
KERNAL_CHKIN    = $FFC6
; Set output channel
KERNAL_CHKOUT   = $FFC9
KERNAL_CLRCHN   = $FFCC ; Clear channels
; Set file params
KERNAL_SETLFS   = $FFBA
KERNAL_SETNAM   = $FFBD ; Set filename
KERNAL_GETIN    = $FFE4 ; Get character
; Close all files
KERNAL_CLALL    = $FFE7
; was: KERNAL_SCREEN_OUT
; Output to screen only
KERNAL_SCREEN_O = $E716
; was: KERNAL_IRQ_ENTRY
; Normal IRQ entry
KERNAL_IRQ_ENTR = $EA31
KERNAL_IRQ_EXIT = $EA7E ; IRQ exit
KERNAL_SCNKEY   = $EA87 ; Scan keyboard
; was: KERNAL_CURSOR_ON
KERNAL_CURSOR_O = $F142 ; Enable cursor
; Set screen line start
KERNAL_SET_LINE = $E9F0
; was: KERNAL_INT_PRINT
KERNAL_INT_PRIN = $BDCD ; Print integer
; Default vector table
KERNAL_VECTORS  = $FD32
;---------------------------------------
; was: BASIC_WARM_START
; BASIC warm start
BASIC_WARM_STAR = $A474
; CHARGET vectors
BASIC_CHARGET   = $E447
;---------------------------------------
; was: SCREEN_COLOR_ROW25
; Color RAM row 25
SCREEN_COLOR_RO = $D82A
;---------------------------------------
CR_CHAR         = $0D ; Carriage return

; Temp word low byte (numeric parsing)
zp_temp_lo      = $14
; Temp word high byte
zp_temp_hi      = $15
; BASIC current line number low
basic_line_lo   = $37
; BASIC current line number high
basic_line_hi   = $38
; General purpose pointer (2 bytes)
gp_ptr          = $39
; Memory write destination pointer
mem_write_ptr   = $3b
; Block move: end address pointer
block_move_end  = $3d
; Block move: source address pointer
block_move_src  = $3f
; Macro parameter table pointer
macro_param_ptr = $43
; was: blk_label_flag_ptr
; Block-local label defined flags
blk_lbl_fl_ptr  = $45
; was: blk_level_tbl_ptr
; Block nesting level table
blk_lvl_tbl_ptr = $47
; Inline string print pointer
inline_str_ptr  = $49
; Label storage scan pointer
label_scan_ptr  = $4b
; Assembly program counter (PC)
current_address = $4d
; Bottom of free memory (grows down)
memory_bottom   = $4f
; Macro body data pointer
macro_value_ptr = $51
; Patched on exit to trigger BASIC
basic_warm_ptr  = $53
; KERNAL: STOP key flag
kernal_stop_key = $91
; was: kernal_output_dev
; KERNAL: current output device
kern_output_dev = $9a
; KERNAL: message control flag
kernal_msg_flag = $9d
; was: kernal_screen_ptr
; KERNAL: current screen line pointer
kern_screen_ptr = $d1
; KERNAL: cursor column position
print_column    = $d3
; Tokenizer work pointer
tok_work_ptr    = $f0
; Tokenizer scratch byte
tok_scratch     = $f2
; Work pointer (2 bytes)
work_ptr        = $fb
; Temporary scratch byte
temp_byte_fd    = $fd
; Temporary scratch byte
temp_byte_fe    = $fe
; Stack: token parse buffer char 0
parse_field_buf = $100
; was: parse_field_buf1
; Stack: token parse buffer char 1
prs_field_buf1  = $101
; was: parse_field_buf2
; Stack: token parse buffer char 2
prs_field_buf2  = $102
; was: parse_field_buf3
; Stack: mnemonic prefix storage
prs_field_buf3  = $103
; Tokenizer scratch
tok_scratch_10a = $10a
; Tokenizer work byte
tok_work_10c    = $10c
; Tokenizer work byte
tok_work_10d    = $10d
; Tokenizer: last input char read
tok_input_char  = $10e
; Mnemonic field buffer char 0
mnemonic_buf    = $10f
; Mnemonic field buffer char 1
mnemonic_buf1   = $110
; Tokenizer: label area number
tok_label_area  = $120
; Tokenizer: label index number
tok_label_index = $121
; was: line_end_sentinel
; End-of-line marker ($0D sentinel)
ln_end_sentinel = $145
; 40-char line edit buffer
line_buffer_200 = $200
opcode_buf      = $2c0 ; 3 bytes
; was: SOURCE_STORAGE_TOP
; Top of source code storage area
SOURCE_STORAGE_ = $7feb
; Cold start signature check
signature       = $7fec
; Editor: tab stop column
tab_position    = $cb00
; Source data read pointer (2 bytes)
source_p        = $cb01
; was: src_current_line_flags
; Current line: type+length byte
src_cur_ln_flg  = $cb03
; Source storage: end pointer low
source_end_lo   = $cb04
; Source storage: end pointer high
source_end_hi   = $cb05
; Current line number (2 bytes)
current_line    = $cb06
; was: destination_line
; Navigation target line (2 bytes)
destination_ln  = $cb08
; was: screen_line_start
; First source line visible on screen
scr_line_start  = $cb0a
; was: cursor_x_position
; Cursor column (0-39)
curs_x_position = $cb0c
; was: cursor_y_position
; Cursor row (0-24)
curs_y_position = $cb0d
; Cursor: active tab position
cursor_tab      = $cb0e
; was: editor_split_mode
; Editor: screen split mode flag
editor_split_md = $cb0f
; was: insert_char_mode
; Editor: insert vs overwrite mode
ins_char_mode   = $cb10
; Editor: raw ASCII input mode
raw_mode_flag   = $cb11
; Total source lines in memory
memory_lines    = $cb12
; Source bytes used: pointer low
source_used_lo  = $cb14
; Source bytes used: pointer high
source_used_hi  = $cb15
; was: currect_color_set
; Active color scheme index
currect_color_s = $cb16
; Find: search string length
find_str_len    = $cb17
; Replace: replacement string length
replace_str_len = $cb18
; Free memory tracker: low
free_mem_lo     = $cb19
; Free memory tracker: high
free_mem_hi     = $cb1a
error_count     = $cb1e ; word
; Assembly: print listing flag
asm_print_flag  = $cb23
; was: asm_to_file_flag
; Assembly: compile to file flag
asm_to_fil_flag = $cb24
; Mark storage: 10 marks + S + E
mark_lines      = $cb28
; Find: string buffer
find_str_buf    = $cb37
; Find: buffer extension
find_str_buf3   = $cb3a
; Block: start line low
block_start_lo  = $cb3c
; Block: start line high
block_start_hi  = $cb3d
; Block: end line low
block_end_lo    = $cb3e
; Block: end line high
block_end_hi    = $cb3f
; was: find_pattern_buf
; Find/replace: pattern storage
find_pattern_bu = $cb40
; Function key string definitions
fkey_strings    = $cb5a
; Replace: string buffer
replace_str_buf = $cb96
; was: replace_pattern_buf
; Replace: pattern buffer
repl_pattern_bu = $cb9a
; Line copy/paste buffer (40 bytes)
line_copy_buf   = $cbb8
; Line copy buffer: byte 1
line_copy_buf1  = $cbb9
; was: line_index_table
; One flags/length byte per source line
line_idx_table  = $cc00
; was: label_value_store
; 2 bytes/label under ROM (8 banks)
lbl_value_store = $e000
; Label name index: low bytes
labels_low      = $ec00
; Label name index: high bytes
labels_high     = $ec30
; was: labels_mem_start
; Label name string storage start
labels_mem_strt = $ec60
; KERNAL: clear screen
clrscr          = $e544
; ======================================
; ENTRY POINT
; ======================================
start
        ; Jump to main initialization
        ; (cold/warm start dispatcher)
        jmp start2

bank_in_roms
        lda #$37
        sta $01
        rts
; Multi-purpose temp byte (disk read,
; key scan, etc.)
temp_result
        .byte $00
; Multi-purpose counter (disk bytes,
; scroll count)
temp_counter
        .byte $00
; Memory block move: direction ($FF=up,
; other=down)
move_direction
        .byte $ff
; Memory block move: bytes per iteration
move_byte_count
        .byte $0a
; Memory block move: source pointer low
block_src_lo
        .byte $18
; Memory block move: source pointer high
block_src_hi
        .byte $00
; Saved current_line before parse (low)
saved_line_lo
        .byte $12
; Saved current_line before parse (high)
saved_line_hi
        .byte $27
; Saved source_p before parse (low)
saved_source_lo
        .byte $e6
; Saved source_p before parse (high)
saved_source_hi
        .byte $17
; Color attribute for current display
; line
line_color
        .byte $00,$00
; Input routine: $FF = cancelled/raw
; mode
; was: input_cancel_flag
inp_cancel_flag
        .byte $ff
; Last key character processed by editor
last_key_char
        .byte $00
; Find: rightmost column to search
find_end_col
        .byte $27
; File I/O: address low byte
file_addr_lo
        .byte $16
; File I/O: address high byte
file_addr_hi
        .byte $00,$00,$00,$00
; Parse: old line length minus new
; length
; was: old_new_len_diff
old_new_len_dif
        .byte $fc
; Nonzero = line buffer has unsaved
; changes
; was: line_modified_flag
line_mod_flag
        .byte $00
; File I/O: byte count for read/write
io_byte_count
        .byte $06
; File I/O: temp address
io_addr_temp
        .byte $f8,$00
; Label list: filter mode for output
; was: label_filter_flag
lbl_filter_flag
        .byte $23,$00
; Replace: $FF = replace all occurrences
; was: replace_all_flag
repl_all_flag
        .byte $ff,$00,$00,$00,$00
; Line number before parse operation
; (low)
; was: pre_parse_line_lo
pre_prs_line_lo
        .byte $13
; Line number before parse operation
; (high)
; was: pre_parse_line_hi
pre_prs_line_hi
        .byte $00
;---------------------------------------
;exit
; ======================================
; EXIT TO BASIC (arrow + !)
; ======================================
arrow_excl
        ; Restore original KERNAL/IDE64
        ; vectors before returning to
        ; BASIC
        jsr check_ide64
        ldx #11
restore_io_vecs
        lda BASIC_CHARGET,x
        bcc store_io_vec
        lda oldvectors2,x
store_io_vec
        sta $300,x
        dex
        ; end restore_io_vecs
        bpl restore_io_vecs
arrow_1
        ; Flush any pending line edit,
        ; enable all ROMs, reset BASIC
        ; state
        jsr pharse_ln_if_an
        lda #BANK_ALL_ROM
        sta $1
        jsr reset_vecto_334
        lda #$4c ;"L"
        sta basic_warm_ptr+1
        jsr clrscr
        ; If BASIC line pointer is past
        ; our source area,
        ; pull it back by 100 lines to
        ; avoid corruption
        lda basic_line_lo
        cmp source_used_lo
        lda basic_line_hi
        sbc source_used_hi
        blt exit_to_basic
        sec
        lda source_used_lo
        sbc #$64 ;100
        sta basic_line_lo
        lda source_used_hi
        sbc #0
        sta basic_line_hi
exit_to_basic
        jmp BASIC_WARM_STAR
txt_eqdollar
        ; .null = string data terminated
        ; by $00 byte
        .null "= $"
txt_labeltab
        .text $8d,$93
        .text "; **** lABELTAB ****",$8d
        .null $8d
; was: txt_end_labeltab
txt_end_lbltab
        .text $8d
        .text "; **** eNDLABELTAB ****"
        .null $8d
;---------------------------------------
;---------------------------------------
print_ay
        sta gp_ptr
        sty gp_ptr+1
        ldy #0
; was: print_string_loop
print_str_loop
        lda (gp_ptr),y
        beq print_str_done
        jsr KERNAL_CHROUT
        iny
        ; end print_str_loop
        bne print_str_loop
; was: print_string_done
print_str_done
        rts
dollar_char
        .byte $24
;---------------------------------------
;---------------------------------------
; was: check_device_present
chk_device_pres
        lda #0
        sta $90
        lda #15
        ldx drive_num_ref+1
        tay
        jsr KERNAL_SETLFS
        lda #0
        sta $b7
        jsr KERNAL_OPEN
        lda #15
        jsr KERNAL_CLOSE
        lda $90
        rts
;---------------------------------------
; ======================================
; DISK DIRECTORY (arrow + *)
; ======================================
arrow_star
        jsr pharse_ln_if_an
        ; Verify drive is online before
        ; attempting directory read
        jsr chk_device_pres
        beq device_ok_rts
        ldx #$1e ;"*"
        ;device not present
        jmp show_editor_err
device_ok_rts
        lda #$0d ;13
        jsr KERNAL_CHROUT
        jsr clrscr
        lda #BANK_ALL_ROM
        sta $1
        ; Open directory channel: device
        ; from $BA, secondary address
        ; $60
        ; Then read and display entries
        ; in blocks of 3 bytes
        ; (lo/hi/type)
        lda #4
        ldx $ba
        ldy #$60
        jsr KERNAL_SETLFS
        lda #1
        ldx #<dollar_char
        ldy #>dollar_char
        jsr KERNAL_SETNAM
        jsr KERNAL_OPEN
        ldx #4
        jsr KERNAL_CHKIN
        lda #0
        sta $90
        ldy #3
dir_read_loop
        sty temp_counter
        jsr KERNAL_CHRIN
        sta temp_result
        ldy $90
        bne dir_close_chan
        jsr arrow_c_3
        ldy $90
        bne dir_close_chan
        ldy temp_counter
        dey
        ; end dir_read_loop
        bne dir_read_loop
        ldx temp_result
        jsr KERNAL_INT_PRIN
        lda #$20 ;" "
        jsr KERNAL_CHROUT
dir_print_name
        jsr KERNAL_CHRIN
        ldx $90
        bne dir_close_chan
        tax
        beq dir_next_entry
        jsr KERNAL_CHROUT
        jmp dir_print_name
dir_next_entry
        lda #$0d ;13
        jsr KERNAL_CHROUT
        ldy #2
        ; end dir_read_loop
        bne dir_read_loop
; was: dir_close_channel
dir_close_chan
        jsr KERNAL_CLRCHN
        lda #4
        jsr KERNAL_CLOSE
dir_finish
        lda #<txt_press_any_k
        ldy #>txt_press_any_k
        jsr print_ay
-       jsr KERNAL_GETIN
        beq -
        jmp start
; was: txt_press_any_key2
txt_press_any_k
        .text $12
        .text "      pRESS A KEY       "
        .null $92
;---------------------------------------
; ======================================
; SHOW MARKS (arrow + :)
; ======================================
arrow_colon
        jsr pharse_ln_if_an
        lda #$ff ;255
        sta temp_result
        lda #<txt_marks_are
        ldy #>txt_marks_are
        jsr print_ay
arrow_colon_1
        lda #$0d ;13
        jsr KERNAL_CHROUT
        ldx #7
        sta print_column
        inc temp_result
        lda temp_result
        cmp #12
        bne +
        lda #$0d ;13
        jsr KERNAL_CHROUT
        jmp dir_finish
+
        asl
        tay
        lda memory_lines
        cmp mark_lines,y
        lda memory_lines+1
        sbc mark_lines+1,y
        blt +
        lda mark_lines+1,y
        ldx mark_lines,y
        ldy #$37
        sty $1
        jsr KERNAL_INT_PRIN
        jmp arrow_colon_1
+
        lda #<txt_not_set
        ldy #>txt_not_set
        jsr print_ay
        jmp arrow_colon_1
txt_marks_are
        .text $93,$8d,$8d,$12
        .text "*   mARKS ARE :  *",$92
        .text $8d
        .text $8d,"0",$8d,"1",$8d,"2"
        .text $8d,"3"
        .text $8d,"4",$8d,"5",$8d,"6"
        .text $8d,"7"
        .text $8d,"8",$8d,"9",$8d,"sTA"
        .text "RT",$8d,"eND",$8d,$13
        .null $11,$11,$11
txt_not_set
        .null "nOT SET"
;---------------------------------------
;l8284
        pha ; dead
        lda #" "
        jsr KERNAL_CHROUT
        pla
;---------------------------------------
hex_print
        pha
        lsr
        lsr
        lsr
        lsr
        jsr +
        pla
        and #%1111
+       cmp #10
        blt +
        adc #6
+       adc #"0"
        jmp KERNAL_CHROUT
;---------------------------------------
hex_print_1
        lda #<labels_mem_strt ;96
        sta labels_low
        lda #>labels_mem_strt ;236
        sta labels_high
        lda #0
        sta source_end_lo
        sta source_end_hi
        rts
;---------------------------------------
arrow_f1
        ldx #$1b ;27
        jsr print_message
;---------------------------------------
reset_f_keys
        ldy #4*16-1
-       lda default_fkey_st,y
        sta fkey_strings,y
        dey
        bpl - ; end loop
        rts
; was: default_fkey_strings
default_fkey_st
        .text $0b,'.TEXT " "',$9d,$9d
        .text $20,$20,$20,$20
        .text $04,$5f,"3RS           "
        .text $0b,".BYTE $00",$9d,$9d
        .text $20,$20,$20,$20
        .text $02,$5f,$14
        .text "             "
turbo_signature
        .text "TURBO"
;---------------------------------------
; ======================================
; INITIALIZATION
; ======================================
; was: set_default_settings
set_default_set
        ldy #4
; was: set_default_settings_1
set_default_s_1
        lda turbo_signature,y
        sta signature,y
        dey
        ; end set_default_s_1
        bpl set_default_s_1
        jsr reset_f_keys
        jsr hex_print_1
        lda #0
        sta free_mem_lo
        sta free_mem_hi
        lda #0
        sta ins_char_mode
        lda #$ff ;255
        sta editor_split_md
        lda #0
        sta curs_x_position
        lda #0
        sta curs_y_position
        sta currect_color_s
        lda #9
        sta tab_position
        sta cursor_tab
        ldy #$17 ;23
        lda #$ff ;255
; was: set_default_settings_2
set_default_s_2
        sta mark_lines,y
        dey
        ; end set_default_s_2
        bpl set_default_s_2
        sei
        lda $1
        pha
        lda #BANK_ALL_RAM
        sta $1
        ldy #24
        lda #0
-       sta line_idx_table,y
        dey
        bpl -
        pla
        sta $1
        cli
        lda #0
        sta current_line
        sta current_line+1
        sta scr_line_start
        sta scr_line_start+1
        lda #<SOURCE_STORAGE_
        sta source_p
        lda #>SOURCE_STORAGE_
        sta source_p+1
        lda #$16 ;22
        sta memory_lines
        lda #0
        sta memory_lines+1
        ldy #$17 ;23
        lda #$7f ;127
; was: set_default_settings_3
set_default_s_3
        sta mark_lines,y
        dey
        ; end set_default_s_3
        bpl set_default_s_3
        rts
start2
        lda #<$2000
        ldx #>$2000 ;" "
        sta current_address
        stx current_address+1

        ldy #$1c ;28
        lda #0
start2_dec
        sta SID_BASE,y
        dey
        bpl start2_dec
        lda #0
        sta 646
        lda #22
        sta VIC_MEMORY_CTRL
        jsr clrscr

        lda #BANK_NO_BASIC
        sta $1
; was: warm_start_entry
warm_strt_entry
        jsr cold_start_init
        jsr reset_vecto_334
        ldy #5
warm_wait_loop
        dey
        bmi warm_inst_irq
        lda turbo_signature,y
        cmp signature,y
        beq warm_wait_loop
warm_do_init
        jsr set_default_set
; was: warm_install_irq
warm_inst_irq
        sei
        lda #<irq_normal
        sta $314
        lda #>irq_normal
        sta $315
        cli
        ldx #2
        jsr print_message
warm_recalc_src
        jsr recalc_src_ptrs
        lda #0
        sta line_mod_flag
        sta raw_mode_flag
        ldx currect_color_s
        lda border_colors,x
        sta VIC_BORDER_COL
        lda paper_colors,x
        sta VIC_BG_COL
        lda #0
        jsr adjust_scr_pos
        jsr redr_all_lns_on
        jmp editor_main_lp
;---------------------------------------
jump_on_line
        lda $1
        pha
        sei
        ldy #$34
        sty $1
        ldy #0
        sec
        lda current_line
        sbc destination_ln
        pha
        lda current_line+1
        sbc destination_ln+1
        sta temp_counter
        pla
        tax
        bcs jump_on_line_3
jump_on_line_1
        jsr next_line
        inx
        ; end jump_on_line_1
        bne jump_on_line_1
        inc temp_counter
        ; end jump_on_line_1
        bne jump_on_line_1
jump_on_line_2
        jsr get_cur_ln_flg
        sta src_cur_ln_flg
        pla
        sta $1
        cli
        rts
jump_on_line_3
        inx
jump_on_line_4
        dex
        bne jump_on_line_5
        dec temp_counter
        ; end jump_on_line_2
        bmi jump_on_line_2
jump_on_line_5
        jsr prev_line
        jmp jump_on_line_4
;---------------------------------------
next_line
